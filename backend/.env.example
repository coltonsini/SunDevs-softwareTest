# ── SERVIDOR ──────────────────────────────────────────────
PORT=3000

# ── SEGURIDAD ─────────────────────────────────────────────
# Clave secreta para autenticar peticiones al API.
# Debe coincidir con VITE_API_KEY del frontend.
# Genera una clave segura con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=

# ── CORS ──────────────────────────────────────────────────
# URL del frontend. En desarrollo no es necesario cambiarlo.
FRONTEND_URL=http://localhost:5173

# ── SWAGGER ───────────────────────────────────────────────
# Pon 'false' en producción para desactivar la documentación pública.
SWAGGER_ENABLED=true